{
  "name": "butler",
  "version": "0.0.1",
  "description": "全能管家 — 独立聊天窗口 (Electron + Claude Agent SDK), 复用订阅认证, 真 usage 上下文条 + 自主压缩",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.fantasyxxj.butler",
    "productName": "全能管家",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!test-*.js",
      "!scripts/**",
      "!build/**",
      "!release/**",
      "!personas.json",
      "!personas.json.bak",
      "!.opentabs.json",
      "!.session.json.migrated",
      "!.claude/**",
      "!memory/**",
      "!workspace/**",
      "!docs/**",
      "!**/.DS_Store"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "extraResources": [
        { "from": "build/bin/mac/${arch}/claude", "to": "bin/claude" }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png",
      "extraResources": [
        { "from": "build/bin/win/${arch}/claude.exe", "to": "bin/claude.exe" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
